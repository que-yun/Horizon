# Environment Variables

# AI API Keys (configure at least one)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx
MINIMAX_API_KEY=xxx
DASHSCOPE_API_KEY=xxx

# WebHook Url (optional for sending notifications)
HORIZON_WEBHOOK_URL=https://xxx

# GitHub Token (optional but recommended for higher rate limits)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
GITHUB_TOKEN=ghp_xxx

# Optional proxy for Horizon host process
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost

# Optional proxy for local RSSHub container
# On macOS / Docker Desktop, use host.docker.internal to reach host proxy
RSSHUB_PROXY_URI=http://host.docker.internal:7890
RSSHUB_PROXY_URL_REGEX=.*
RSSHUB_REQUEST_TIMEOUT=15000

# Optional local changedetection.io service
CHANGEDETECTION_BASE_URL=http://127.0.0.1:15000
CHANGEDETECTION_API_TOKEN=
CHANGEDETECTION_RSS_TOKEN=

# Optional Feishu/Lark bot webhook for local automation notifications
FEISHU_BOT_WEBHOOK_URL=
FEISHU_BOT_SECRET=

# Optional site URL override for Feishu cards
HORIZON_PAGES_URL=

# Optional local automation schedule (launchd uses local timezone)
HORIZON_SCHEDULE_HOUR=8
HORIZON_SCHEDULE_MINUTE=30

# Optional local automation runtime
HORIZON_RUN_HOURS=24
HORIZON_GIT_REMOTE=origin
HORIZON_GIT_BRANCH=main

# Optional Semantic Scholar API key
# Without it, Semantic Scholar source should stay disabled to avoid 429s
SEMANTIC_SCHOLAR_API_KEY=
