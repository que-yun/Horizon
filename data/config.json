{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-5.4",
    "base_url": "http://127.0.0.1:15721/v1",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.2,
    "max_tokens": 8192,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langgraph",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "temporalio",
        "repo": "temporal",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "qdrant",
        "repo": "qdrant",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "open-telemetry",
        "repo": "opentelemetry-collector",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 25,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "llm-engineering"
      },
      {
        "name": "Chip Huyen",
        "url": "https://huyenchip.com/feed.xml",
        "enabled": true,
        "category": "ai-systems"
      },
      {
        "name": "Lilian Weng",
        "url": "https://lilianweng.github.io/index.xml",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-products"
      },
      {
        "name": "OpenAI News",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "official-updates"
      },
      {
        "name": "OpenAI Developers",
        "url": "https://developers.openai.com/rss.xml",
        "enabled": true,
        "category": "official-openai"
      },
      {
        "name": "OpenAI Cookbook Commits",
        "url": "https://github.com/openai/openai-cookbook/commits/main.atom",
        "enabled": true,
        "category": "official-openai"
      },
      {
        "name": "Go Blog",
        "url": "https://go.dev/blog/feed.atom",
        "enabled": true,
        "category": "go-backend"
      },
      {
        "name": "Anthropic Engineering (RSSHub)",
        "url": "http://127.0.0.1:1200/anthropic/engineering",
        "enabled": true,
        "category": "official-updates"
      },
      {
        "name": "Anthropic Research (RSSHub)",
        "url": "http://127.0.0.1:1200/anthropic/research",
        "enabled": true,
        "category": "official-updates"
      },
      {
        "name": "Anthropic Docs Release Notes (ChangeDetection)",
        "url": "http://127.0.0.1:15000/rss?token=${CHANGEDETECTION_RSS_TOKEN}&tag=anthropic-docs",
        "enabled": true,
        "category": "official-updates"
      },
      {
        "name": "Hugging Face Daily Papers (RSSHub)",
        "url": "http://127.0.0.1:1200/huggingface/daily-papers/week/50",
        "enabled": true,
        "category": "papers"
      },
      {
        "name": "arXiv AI/LLM",
        "url": "https://export.arxiv.org/api/query?search_query=cat:cs.AI+OR+cat:cs.CL+OR+cat:cs.LG&sortBy=lastUpdatedDate&sortOrder=descending&start=0&max_results=20",
        "enabled": true,
        "category": "papers"
      },
      {
        "name": "Semantic Scholar Agent Systems (ChangeDetection)",
        "url": "http://127.0.0.1:15000/rss?token=${CHANGEDETECTION_RSS_TOKEN}&tag=semantic-scholar",
        "enabled": false,
        "category": "papers"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 3
    },
    "telegram": {
      "enabled": false,
      "channels": []
    }
  },
  "filtering": {
    "ai_score_threshold": 6.8,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
